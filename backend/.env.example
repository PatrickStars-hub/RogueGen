OPENAI_API_KEY=sk-xxx

# 使用 OpenAI 官方（默认）
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o

# 使用 OpenRouter（替换上面两行）
# OPENAI_BASE_URL=https://openrouter.ai/api/v1
# OPENAI_MODEL=anthropic/claude-3.5-sonnet

# 代码生成 & 代码审查专用模型（不填则默认使用 OPENAI_MODEL）
CODE_MODEL=openai/gpt-5.3-codex

PORT=8765

# OpenRouter 可选请求头（使用 OpenRouter 时填写）
# OR_SITE_URL=http://localhost:5173
# OR_SITE_NAME=Roguelike Generator

# ── 图像生成 ──────────────────────────────────────────────────────────────────

# Doubao（火山引擎 Ark）：游戏素材 - 角色、道具、技能图标
DOUBAO_API_KEY=your-doubao-api-key-here
DOUBAO_IMAGE_MODEL=doubao-seedream-5-0-260128
DOUBAO_BASE_URL=https://ark.cn-beijing.volces.com/api/v3

# Nano Banana Pro（globalai.vip）：背景图 & 关键艺术图
NANO_BANANA_PRO_API_KEY=your-nano-banana-pro-api-key-here
NANO_BANANA_PRO_BASE_URL=https://globalai.vip/v1beta
NANO_BANANA_PRO_MODEL=gemini-3-pro-image-preview

# 生成图片保存目录（相对于 backend/，无需修改）
ART_OUTPUT_DIR=static/art
